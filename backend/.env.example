# Copy to backend/.env (which is gitignored). The dashboard works WITHOUT these:
# every client always shows a static "yesterday's briefing" from the dataset — the
# zero-live-LLM floor. These only enable the fresh AI overlay.

# Your Anthropic API key. Leave blank to run fully offline on static briefings.
ANTHROPIC_API_KEY=

# Model for NBC generation. Default is Haiku (fast/cheap for short structured output);
# override to a stronger model without touching code.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
